# Supabase Configuration
# Salin file ini menjadi .env.local dan isi dengan kredensial project Supabase kamu.
# Dapatkan nilai ini dari: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
